programa {
  funcao inicio() {
    inteiro nota1, nota2, nota3, nota4
    real media 

    escreva("Nota 1: ")
    leia(nota1)

    escreva("Nota 2: ")
    leia(nota2)

    escreva("Nota 3: ")
    leia(nota3)

    escreva("Nota 4: ")
    leia(nota4)

    media=(nota1+nota2+nota3+nota4)/4
    escreva("A sua média é: ", media)
  }
}
