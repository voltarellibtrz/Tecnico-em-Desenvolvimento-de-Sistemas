programa {
  funcao inicio() {
    real baseMaior, baseMenor, altura, area

    escreva("Base Maior: ")
    leia(baseMaior)

    escreva("Base Menor: ")
    leia(baseMenor)

    escreva("Altura: ")
    leia(altura)
    
    area = ((baseMaior+baseMenor)*altura)/2
    escreva("Área do trapézio: ", area)
    
      }
}
