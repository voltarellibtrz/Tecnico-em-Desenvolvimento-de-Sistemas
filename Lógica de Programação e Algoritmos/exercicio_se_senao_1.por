programa {
  funcao inicio() {
    inteiro num1, num2

    escreva("Digite num1: ")
    leia(num1)

    escreva("Digite num2: ")
    leia(num2)

    se(num1>num2){
    escreva("num1>num2")
    }

    senao se(num2>num1){
    escreva("num2>num1")
    }

    senao se(num1 == num2){
    escreva("Os números são iguais! ")
    }
  }
}

