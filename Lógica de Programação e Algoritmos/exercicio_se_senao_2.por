programa {
  funcao inicio() {
    inteiro idade

    escreva("Digite sua idade: ")
    leia(idade)

    se(idade>=0 e idade<=12)
    escreva("É uma criança!🧒👧👶 ")
    
    se(idade>=13 e idade<=17)
    escreva("É um adolescente!👦👩 ")

    se(idade>=18 e idade<=59)
    escreva("É um adulto!👩👨 ")

    se(idade>=60)
    escreva("É um idoso!👵👴 ")


  }
}
